{
  "js": {
    "type": "terser",
    "terser": {
      "mangle": {
        "toplevel": true,
        "reserved": ["pushToast", "addKeyboardListener",
        "addClickKeyboardListener", "easySetup",
        "addUsernameFieldWatchers", "translateErrorObject",
        "openAltText", "openPostAltEditor"]
      }
    },
    "putout": {
      "quote": "'",
      "mangle": false,
      "mangleClassNames": false,
      "removeUnusedVariables": false,
      "removeConsole": false,
      "removeUselessSpread": true
    }
  }
}