{
  "name": "skyscheduler",
  "license": "MIT",
  "homepage": "https://skyscheduler.work",
  "scripts": {
    "dev": "wrangler dev --live-reload",
    "dev:queue": "wrangler dev -c wrangler.toml --persist-to .wrangler/state --live-reload",
    "deploy": "wrangler deploy --minify",
    "auth:generate": "npx auth@latest generate --config src/auth/index.ts --output src/db/auth.schema.ts -y",
    "auth:format": "npx prettier --write src/db/auth.schema.ts",
    "auth": "run-s auth:*",
    "dboptimize": "run-s migrate:*:pragma",
    "generate": "drizzle-kit generate",
    "migrate:local:db": "wrangler d1 migrations apply skyposts --local",
    "migrate:local:pragma": "wrangler d1 execute skyposts --command \"PRAGMA optimize\" --local -y",
    "migrate:local": "run-s migrate:local:*",
    "migrate:prod:db": "wrangler d1 migrations apply skyposts --remote",
    "migrate:prod:pragma": "wrangler d1 execute skyposts --command \"PRAGMA optimize\" --remote -y",
    "migrate:prod": "run-s migrate:prod:*",
    "migrate:all": "npm run migrate:local && npm run migrate:prod",
    "minify:js:main": "minify assets/js/main.js > assets/js/main.min.js",
    "minify:js:app": "cat assets/js/*Helper.js | minify --js > assets/js/app.min.js",
    "minify:style:site": "minify assets/css/stylesheet.css > assets/css/stylesheet.min.css",
    "minify:style:dash": "minify assets/css/dashboard.css > assets/css/dashboard.min.css",
    "minify:js": "run-p minify:js:**",
    "minify:style": "run-p minify:style:**",
    "minify": "run-p minify:*",
    "invite:generate": "npx human-id@4.1.3 lowercase -",
    "invite:local": "wrangler kv key put --binding INVITE_POOL --local",
    "invite:remote": "wrangler kv key put --binding INVITE_POOL --remote",
    "openapi": "npx chanfana -o openapi.json",
    "sitemap:make": "sscli > assets/sitemap.xml",
    "sitemap:clean": "replace-in-file \"/homepage|\\.tsx/g\" \"\" assets/sitemap.xml",
    "sitemap": "run-s sitemap:*",
    "types": "wrangler types src/wrangler.d.ts"
  },
  "scriptsComments": {
    "dev": "run this application in development locally",
    "dev:queue": "runs the application in development but with queue support",
    "deploy": "uploads the local version directly to your worker",
    "auth": "builds the better auth db tables, should only ever be used once",
    "generate": "generates any db schema changes and their migration sql commands",
    "migrate": "syncs the current migration steps directly into the given db, then optimizes it",
    "migrate:prod": "runs the above but only for production",
    "migrate:local": "runs migrate but only for local",
    "dboptimize": "runs database optimizations for both local and production dbs",
    "minify": "runs minification/bundling on client scripts, done every build",
    "invite:generate": "generates an acceptable invite code",
    "invite:local <code> <usage #>": "commits an invite code directly to the local invite key store",
    "invite:remote <code> <usage #>": "the above for remote",
    "openapi": "creates the openapi.json file",
    "sitemap": "creates a sitemap.xml file",
    "types": "generates wrangler types"
  },
  "dependencies": {
    "@atproto/api": "^0.20.25",
    "@hono/standard-validator": "^0.2.3",
    "better-auth": "^1.6.23",
    "better-auth-cloudflare": "^0.3.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "hono-openapi": "^1.3.0",
    "human-id": "^4.2.0",
    "image-dimensions": "^2.5.1",
    "just-flatten-it": "^5.2.0",
    "just-has": "^2.3.0",
    "just-is-empty": "^3.4.1",
    "just-random": "^3.2.0",
    "just-safe-get": "^4.2.0",
    "just-split": "^3.2.0",
    "just-truncate": "^2.2.0",
    "just-unique": "^4.2.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^24.13.2",
    "drizzle-kit": "^0.31.10",
    "minify": "^14.1.0",
    "npm-run-all2": "^9.0.2",
    "replace-in-file": "^8.4.0",
    "static-sitemap-cli": "^2.2.7",
    "typed-htmx": "^0.3.1",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "better-auth-cloudflare": {
      "@cloudflare/workers-types": "latest"
    }
  },
  "engines": {
    "node": ">=24.15"
  }
}
